# Supabase pooler URL (runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Supabase direct URL (migrations)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Required by NextAuth in production (and recommended in dev)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Optional if using /api/cron/recurring endpoint
CRON_SECRET="replace-with-random-secret"

# Dedicated Postgres DB for integration tests (recommended)
TEST_DATABASE_URL="postgresql://postgres:<password>@localhost:5432/hornero_test?sslmode=disable"
# Optional direct URL override for migrations in tests
TEST_DIRECT_URL="postgresql://postgres:<password>@localhost:5432/hornero_test?sslmode=disable"

# Web Push configuration
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
